# =============================================================
# SIMARIS - Environment Variables Backend
# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env
# =============================================================

# --- Koneksi Database PostgreSQL ---
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/NAMA_DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/inventory_db

# --- Environment Aplikasi ---
# Nilai: development | production
NODE_ENV=development

# --- Port Server Backend ---
# Default: 8081 (sesuai plan.md)
PORT=8081

# --- JWT Secret Key ---
# Gunakan string acak yang panjang dan aman (min 32 karakter)
# Generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=ganti_dengan_secret_key_yang_sangat_panjang_dan_aman

# --- JWT Expiry ---
# Contoh: 1h, 8h, 7d
JWT_EXPIRES_IN=8h

# --- AWS Region ---
# Region deploy: Singapore
AWS_REGION=ap-southeast-1

# --- AWS S3 Bucket untuk upload foto barang ---
AWS_S3_BUCKET=simaris-uploads

# --- AWS Credentials ---
# Dapatkan dari IAM Console AWS
AWS_ACCESS_KEY_ID=isi_access_key_aws_kamu
AWS_SECRET_ACCESS_KEY=isi_secret_key_aws_kamu

# --- Instance ID ---
# WAJIB diisi secara manual di tiap EC2 instance untuk verifikasi load balancer
# Contoh: instance-1 | instance-2
# Di lokal boleh diisi: local-dev
INSTANCE_ID=local-dev

# --- CORS Origin ---
# URL frontend yang diizinkan mengakses API ini
FRONTEND_URL=http://localhost:5173
